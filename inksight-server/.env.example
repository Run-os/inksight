# ============================================
# InkSight 新后端服务 (inksight-server) 环境配置
# 部署时复制本文件为 .env 并填入真实值（站点根目录）
# ============================================

# 服务监听端口（设备将访问 http://<server>:<PORT>）
PORT=5543

# 可选：设备鉴权共享密钥。设置后，设备拉取接口需在 Header 带 X-Device-Secret: <值>
# 留空则不校验（仅建议内网/测试环境）
DEVICE_SHARED_SECRET=

# ============================================
# 滴答清单 (Dida365) OAuth 应用凭据
# 在 https://developer.dida365.com 创建应用获取
# ============================================
DIDA_CLIENT_ID=your_dida365_client_id
DIDA_CLIENT_SECRET=your_dida365_client_secret
# 必须与 Dida365 开发者后台配置的 Redirect URI 完全一致（指向本服务的 callback 路由）
DIDA_REDIRECT_URI=http://localhost:8000/admin/dida365/callback
# 授权范围（token 交换时勿带 scope）。只读展示用 tasks:read 即可
DIDA_SCOPE=tasks:read
# 可选：只展示某个清单(项目)的任务；留空则聚合所有清单的待办
DIDA_PROJECT_ID=

# 可选：预填访问令牌（若已通过 OAuth 取得，可省去网页授权步骤）
# 留空则由 OAuth 流程写入 .dida_tokens.json
DIDA_ACCESS_TOKEN=
DIDA_REFRESH_TOKEN=

# 图片资源目录（相对服务根目录），本服务扫描该目录提供设备拉取
INKSIGHT_IMAGES_DIR=images
